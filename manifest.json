{
  "manifest_version": 3,
  "name": "한글 맞춤법 검사기",
  "version": "1.1.0",
  "description": "웹페이지에서 한글 맞춤법을 검사합니다.",
  "permissions": ["activeTab", "contextMenus", "storage", "tabs", "scripting"],
  "host_permissions": [
    "https://nara-speller.co.kr/*",
    "https://m.search.naver.com/*",
    "https://speller.cs.pusan.ac.kr/*",
    "https://dic.daum.net/*",
    "https://www.saramin.co.kr/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
